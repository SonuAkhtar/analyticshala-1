# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code (local agent config, memory, plans)
.claude/
.claude.json
CLAUDE.local.md

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# OS-generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linter / formatter caches
.eslintcache
.stylelintcache
.prettiercache

# Turbo / build caches
.turbo/
.cache/

# Logs
*.log
logs/
